generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Resume {
  id           String      @id @default(cuid())
  filename     String
  uploadDate   DateTime    @default(now())
  pdfText      String
  jdText       String?
  analysisJson String?
  status       String      @default("uploaded")
  errorMessage String?
  tag          String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  recordings   Recording[]

  @@index([uploadDate])
  @@index([status])
  @@index([tag])
}

model Recording {
  id        String   @id @default(cuid())
  resumeId  String
  filename  String
  duration  Int
  data      Bytes
  createdAt DateTime @default(now())
  resume    Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId, createdAt])
}

model Settings {
  id              Int      @id @default(1)
  provider        String   @default("AiHubMix")
  apiKeyAihubmix  String   @default("")
  apiKeyDeerapi   String   @default("")
  apiKeyYescode   String   @default("")
  model           String   @default("gemini-3.1-pro-preview")
  updatedAt       DateTime @updatedAt
}
