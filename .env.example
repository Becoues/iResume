# ============================================================
# 简历智评 - 环境变量配置
# 复制此文件为 .env.local 并填入你的真实值
# ============================================================

# --- API Key（二选一，填一个即可）---

# 方式一：AiHubMix（推荐）
# 获取方式：https://aihubmix.com 注册后在控制台创建 Key
AIHUBMIX_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 方式二：YesCode
# 获取方式：https://co.yes.vg 联系获取 team key
# YESCODE_API_KEY=team-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- 模型选择（可选，默认 gemini-3.1-pro-preview）---
# 可选值：gemini-3.1-pro-preview, claude-sonnet-4-5, gpt-5.4
# MODEL=gemini-3.1-pro-preview

# --- 数据库路径（默认即可，无需修改）---
DATABASE_URL="file:./prisma/dev.db"
